# Copy to .env.local for local development.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Public site URL (no trailing slash). Used for Stripe success/cancel redirects and auth email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Stripe (server-only; never expose to the client)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price ids (Dashboard → Products → Prices)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_POWER_MONTHLY=
STRIPE_PRICE_POWER_ANNUAL=
STRIPE_PRICE_LIFETIME=
VAULT_ENCRYPTION_KEY=
ALLOWED_ADMIN_EMAILS=
ANTHROPIC_API_KEY=
# Server-side Groq key for Manual Compare synthesis and built-in Groq lanes
GROQ_API_KEY=
RESEND_API_KEY=
# Optional verified sender for Resend (defaults to onboarding@resend.dev in dev)
RESEND_FROM=LettiB <notifications@lettib.com>
STANDUP_EMAIL_TO=
